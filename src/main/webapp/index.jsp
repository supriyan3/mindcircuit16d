<script>
    document.addEventListener('DOMContentLoaded', () => {
      const cursor = document.querySelector('.snappy-cursor');
      const hero = document.querySelector('.hero');

      let mouseX = 0, mouseY = 0;
      let currentX = 0, currentY = 0;
      let isDetached = false;
      let isInHero = false;
      let detachTimeout;
      const speed = 0.15;

      function animateCursor() {
        if (!isDetached && isInHero) {
          currentX += (mouseX - currentX) * speed;
          currentY += (mouseY - currentY) * speed;
          cursor.style.left = `${currentX + 20}px`;
          cursor.style.top = `${currentY + 20}px`;
        }
        requestAnimationFrame(animateCursor);
      }

      animateCursor();

      document.addEventListener('mousemove', (e) => {
        if (!isDetached) {
          mouseX = e.clientX;
          mouseY = e.clientY;
        }
      });

      function enterHero() {
        isInHero = true;
        isDetached = false;
        cursor.classList.remove('hidden', 'idle');
        cursor.classList.add('following');

        clearTimeout(detachTimeout);
        detachTimeout = setTimeout(() => {
          isDetached = true;
          cursor.classList.remove('following');
          cursor.classList.add('idle');

          // Get hero's position and animate cursor to top-right
          const heroRect = hero.getBoundingClientRect();
          const topOffset = window.scrollY + heroRect.top + 40;
          const rightOffset = window.innerWidth - 160; // 120px width + margin
          cursor.style.left = `${rightOffset}px`;
          cursor.style.top = `${topOffset}px`;
        }, 5000); // 5 seconds
      }

      function leaveHero() {
        isInHero = false;
        isDetached = false;
        cursor.classList.remove('following', 'idle');
        cursor.classList.add('hidden');
        clearTimeout(detachTimeout);
      }

      function checkHeroVisibility() {
        const heroRect = hero.getBoundingClientRect();
        if (heroRect.bottom > 0 && heroRect.top < window.innerHeight) {
          enterHero();
        } else {
          leaveHero();
        }
      }

      checkHeroVisibility();
      window.addEventListener('scroll', checkHeroVisibility);
    });
  </script></div><div class="snappy-home-animation w-embed w-script"><style>
/*
  CSS Animation for .jet-pack-snappy-point.home-hero element
  Version 11: Adjusted end position 50px higher than original 'below button' position.
*/

/* 1. Main Flight Animation - No Bounce */
@keyframes flyToCenterAndBounce {
  0% {
    transform: translate(-150px, -80px) scale(1) rotate(-25deg);
    opacity: 0;
  }
  5% { /* Start of visible animation */
    transform: translate(-150px, -80px) scale(1) rotate(-25deg);
    opacity: 1; /* Element becomes visible */
    animation-timing-function: ease-in-out;
  }
  100% {
    /* Uses CSS variables for dynamic positioning, with fallbacks. */
    transform: translate(var(--jetpack-end-x, 600px), var(--jetpack-end-y, 400px)) scale(0.95) rotate(5deg); /* Adjusted fallback Y */
    opacity: 1;
  }
}

/* 2. Gentle Hovering Animation (Looping) - 15px Vertical Movement */
@keyframes subtleCenterHover {
  0% {
    transform: translate(var(--jetpack-end-x, 600px), var(--jetpack-end-y, 400px)) scale(0.95) rotate(5deg);
  }
  50% {
    transform: translate(var(--jetpack-end-x, 600px), calc(var(--jetpack-end-y, 400px) - 15px)) scale(0.955) rotate(5deg);
  }
  100% {
    transform: translate(var(--jetpack-end-x, 600px), var(--jetpack-end-y, 400px)) scale(0.95) rotate(5deg);
  }
}

/* 3. Styles for the Element */
.jet-pack-snappy-point.home-hero {
  /* Initial state before animation starts */
  transform: translate(-150px, -80px) scale(1) rotate(-25deg);
  opacity: 0; /* Start invisible, JavaScript will make it visible by starting animation */

  /* Default values for CSS variables, can be overridden by JavaScript */
  --jetpack-end-x: 600px; /* Fallback X position */
  --jetpack-end-y: 400px; /* Fallback Y position (adjusted 50px up from original 450px) */

  will-change: transform, opacity;
  /* The animation-name is removed here and applied by a class via JavaScript */
  transition: opacity 0.3s ease-out; /* For smooth fade-in/out triggered by JS */
}

/* Class to trigger the initial flight animation */
.jet-pack-snappy-point.home-hero.is-flying-in {
  animation-name: flyToCenterAndBounce;
  animation-duration: 2700ms;
  animation-fill-mode: forwards;
  animation-iteration-count: 1;
  animation-timing-function: linear; /* Keyframes control specific easing */
}

/* Class for active hovering state */
.jet-pack-snappy-point.home-hero.is-hovering-at-center {
  animation-name: subtleCenterHover;
  animation-duration: 2800ms;
  animation-iteration-count: infinite;
  animation-timing-function: ease-in-out;
  opacity: 1; /* Ensure visibility */
  /* Transform is now handled by the subtleCenterHover animation using CSS variables */
}

/* Class for fading out the jetpack when hero is out of view */
.jet-pack-snappy-point.home-hero.is-fading-out {
  opacity: 0 !important; /* Ensure it fades out, overriding animation opacity if needed */
}
</style>

<script>
/**
 * JavaScript for Jetpack Snappy Animation
 * ----------------------------------------
 * This script handles:
 * 1. Dynamically calculating the jetpack's final resting position (left of and
 * adjusted vertically relative to a target button group) on page load and resize.
 * 2. Initiating the jetpack's flight animation based on hero section visibility.
 * 3. Switching to a hovering animation after the flight completes.
 * 4. Fading out the jetpack when the hero section is scrolled out of view.
 */

let jetpackElement;
let heroSectionElement; // The element that triggers the animation when it's in view
let heroIntersectionObserver;

/**
 * Calculates and applies the target end position for the jetpack animation.
 */
function alignJetpackToEndPosition() {
    // Ensure jetpackElement is defined (it's set in DOMContentLoaded)
    if (!jetpackElement) return false;

    const buttonGroupElement = document.querySelector('.button-group-center');

    if (buttonGroupElement) {
        const jetpackRect = jetpackElement.getBoundingClientRect();
        const jetpackWidth = jetpackRect.width;

        const offsetParent = jetpackElement.offsetParent || document.body;
        const offsetParentRect = offsetParent.getBoundingClientRect();
        const buttonGroupRect = buttonGroupElement.getBoundingClientRect();

        const desiredGapHorizontal = 10; // 10px to the left
        // desiredGapVertical: Positive values are below buttonGroupRect.bottom, negative are above.
        // Original 'below button' position was effectively +20px from buttonGroupRect.bottom.
        // To move 50px up from that original 'below button' position: 20 - 50 = -30.
        // This means the jetpack's top edge will be 30px *above* the bottom edge of the button group.
        const desiredGapVertical = -30;   

        const targetViewportX = buttonGroupRect.left - jetpackWidth - desiredGapHorizontal;
        const targetViewportY = buttonGroupRect.bottom + desiredGapVertical; // Adding a negative gap moves it up

        const finalTranslateX = targetViewportX - offsetParentRect.left;
        const finalTranslateY = targetViewportY - offsetParentRect.top;
        
        jetpackElement.style.setProperty('--jetpack-end-x', finalTranslateX + 'px');
        jetpackElement.style.setProperty('--jetpack-end-y', finalTranslateY + 'px');
        
        // console.log('Jetpack End Position Updated:', { finalTranslateX, finalTranslateY, desiredGapVertical });
        return true;
    } else {
        if (!buttonGroupElement) console.warn('Button group element (.button-group-center) not found for positioning.');
        return false;
    }
}

/**
 * Resets and starts the full jetpack animation sequence.
 */
function playJetpackAnimation() {
    if (!jetpackElement) return;

    // 1. Reset classes and styles
    jetpackElement.classList.remove('is-flying-in', 'is-hovering-at-center', 'is-fading-out');
    
    // Force a reflow. This is a trick to ensure that if classes are re-added quickly,
    // the browser restarts the animation from the beginning.
    void jetpackElement.offsetWidth;

    // 2. Recalculate and set the target position
    if (alignJetpackToEndPosition()) {
        // 3. Start the fly-in animation
        //    A requestAnimationFrame can help ensure styles are applied before animation starts
        requestAnimationFrame(() => {
            jetpackElement.classList.add('is-flying-in');
        });
        // console.log('playJetpackAnimation: Started fly-in');
    } else {
        // console.log('playJetpackAnimation: Could not align, animation not started.');
    }
}

/**
 * Handles visibility changes of the hero section.
 * @param {IntersectionObserverEntry[]} entries - The entries reported by the observer.
 */
function handleHeroVisibility(entries) {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            // Hero section is visible
            // console.log('Hero is IN view');
            // Ensure jetpack is not faded out (in case it was)
            jetpackElement.classList.remove('is-fading-out');

            // Only play animation if it's not already in a visible animated state
            if (!jetpackElement.classList.contains('is-flying-in') && !jetpackElement.classList.contains('is-hovering-at-center')) {
                playJetpackAnimation();
            }
        } else {
            // Hero section is NOT visible
            // console.log('Hero is OUT of view');
            jetpackElement.classList.add('is-fading-out');
            // Reset animation classes so it's ready for the next time it enters view
            jetpackElement.classList.remove('is-flying-in', 'is-hovering-at-center');
        }
    });
}

// Main setup on DOMContentLoaded
document.addEventListener('DOMContentLoaded', function() {
    jetpackElement = document.querySelector('.jet-pack-snappy-point.home-hero');
    // IMPORTANT: Confirm this selector matches your page's hero section.
    heroSectionElement = document.querySelector('.hero'); 

    if (!jetpackElement) {
        console.warn('Jetpack element (.jet-pack-snappy-point.home-hero) not found. Animation will not run.');
        return;
    }

    // Always attempt to align jetpack on load to set initial CSS variables.
    // This is important even if the hero section isn't immediately visible or found,
    // as the variables are used as fallbacks in CSS.
    alignJetpackToEndPosition();

    // Listener for when the 'flyToCenterAndBounce' animation ends to switch to hover
    jetpackElement.addEventListener('animationend', function(event) {
        if (event.animationName === 'flyToCenterAndBounce') {
            jetpackElement.classList.remove('is-flying-in');
            jetpackElement.classList.add('is-hovering-at-center');
            // console.log('Switched to hovering animation');
        }
    });

    if (heroSectionElement) {
        // If hero section is found, set up scroll-based triggers
        const observerOptions = {
            root: null, // Observes intersections relative to the viewport
            rootMargin: '0px', // No margin
            threshold: 0.01    // Trigger if at least 1% of the hero is visible.
                               // Adjust this value if needed (0.0 to 1.0).
                               // 0 means as soon as 1px is visible.
        };
        heroIntersectionObserver = new IntersectionObserver(handleHeroVisibility, observerOptions);
        heroIntersectionObserver.observe(heroSectionElement);
        // console.log('Intersection Observer is watching the hero section.');
    } else {
        // Fallback: If no hero section for scroll triggers, play animation once on load.
        console.warn('Hero section element (.hero) not found. Animation will play once on load without scroll triggers.');
        // Check if position was successfully set before trying to fly in
        if (jetpackElement.style.getPropertyValue('--jetpack-end-x')) { 
             requestAnimationFrame(() => {
                jetpackElement.classList.add('is-flying-in');
            });
        }
    }
});

// Re-align on window resize.
// This updates the CSS variables. If the jetpack is hovering, it will adjust.
// If it's hidden, the variables will be correct for the next time it plays.
window.addEventListener('resize', function() {
    alignJetpackToEndPosition(); 
    // console.log('Window resized, jetpack position recalculated.');
});

</script></div><div class="cookie"><img src="https://cdn.prod.website-files.com/67ebfd6792ff5801a295a16d/682f86ce1e062cab451a2731_snappy-Cookie.png" loading="lazy" alt="" class="image"/><div class="cookie-card"><div class="heading-style-h5 text-color-white text-align-center">We use cookies</div><div class="text-size-small text-color-white text-align-center">But these are yummy non-third party cookies will enhance your experience with Snappy!</div><a id="snappyAcceptButton" data-w-id="9efa0aa0-7dfa-5a06-d5c4-b47134946866" href="#" class="button is-icon is-large is-full w-inline-block"><div class="text-block">Accept</div></a><a id="snappyPreferencesButton" href="#" class="button is-large is-secondary is-full w-button">Preferences</a></div></div><div class="mouse-wrapper"><div data-w-id="9c5672ea-1333-fd1e-8963-c7c3680df814" class="snappy-cursor preload"><img src="https://cdn.prod.website-files.com/67ebfd6792ff5801a295a16d/6823a042b5708009ef9296c5_SnappyPointingNew_240p_60_20fps.webp" loading="lazy" alt="" class="snappy-jetpack"/></div></div><div class="page-wrapper"><div class="main-wrapper background-gradient-primary"><div class="jumbo-nav-wrapper"><div class="navbar-top-border"></div><div data-animation="default" class="navbar5_component large w-nav" data-easing2="ease" fs-scrolldisable-element="smart-nav" data-easing="ease" data-collapse="medium" data-w-id="b2612f8c-cc47-c91d-3802-869c24b839d0" role="banner" data-duration="400"><div class="navbar5_container"><a href="/" aria-current="page" class="navbar5_logo-link w-nav-brand w--current"><img loading="lazy" src="https://cdn.prod.website-files.com/67ebfd6792ff5801a295a16d/682f4b276c24ffb2ae733b5d_wink.webp" alt="Snappy Logo" class="navbar5_logo"/></a><nav role="navigation" class="navbar5_menu w-nav-menu"><div class="navbar5_menu-left holiday"><div data-delay="300" data-hover="true" data-w-id="b2612f8c-cc47-c91d-3802-869c24b839dc" class="navbar5_menu-dropdown w-dropdown"><div class="navbar5_dropdown-toggle holiday st